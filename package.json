{
  "name": "void-rift",
  "version": "1.0.0",
  "description": "VOID RIFT - A browser-based twin-stick shooter built with vanilla HTML, CSS, and JavaScript",
  "main": "index.html",
  "scripts": {
    "start": "python3 -m http.server 5173",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint script.js",
    "lint:fix": "eslint script.js --fix",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:build:android": "npx cap sync android && cd android && ./gradlew bundleRelease",
    "cap:add:android": "npx cap add android"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/astickleyid/shooter-app.git"
  },
  "keywords": [
    "game",
    "shooter",
    "browser-game",
    "twin-stick-shooter",
    "javascript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor-community/admob": "^6.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
